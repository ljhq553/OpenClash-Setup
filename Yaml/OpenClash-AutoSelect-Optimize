# 机场节点订阅
proxy-providers:
  XXdl-Link:
    url: "自己的机场订阅链接"
    type: http
    interval: 86400
    health-check:
      enable: true
      url: https://www.gstatic.com/generate_204
      interval: 300
    proxy: 直连
    exclude-filter: "建议|剩余|到期|网站|更新|重置|失联"
    override:
      additional-prefix: "XXdl-"

# 节点定义
proxies:
  - {name: 直连, type: direct}

# 应用组定义
proxy-groups:
  - {name: ChatGPT, type: select, proxies: [🇺🇸 美国-自动, 🇸🇬 狮城-自动, 🇹🇼 台湾-自动]}
  - {name: TikTok,  type: select, proxies: [🇸🇬 狮城-自动, 🇹🇼 台湾-自动, 🇺🇸 美国-自动]}
  - {name: Spotify, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动]}
  - {name: Disney, type: select, proxies: [🇭🇰 香港-自动, 🇹🇼 台湾-自动, 🇸🇬 狮城-自动]}
  - {name: Netflix, type: select, proxies: [🇺🇸 美国-自动, 🇸🇬 狮城-自动, 🇭🇰 香港-自动]}
  - {name: HBO, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动, 🇹🇼 台湾-自动]}
  - {name: GitHub, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动, 🇹🇼 台湾-自动]}
  - {name: YouTube, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动, 🇹🇼 台湾-自动]}
  - {name: Google, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动, 🇹🇼 台湾-自动]}
  - {name: 🌐 国外, type: select, proxies: [🇭🇰 香港-自动, 🇸🇬 狮城-自动, 🇺🇸 美国-自动, 🇹🇼 台湾-自动]}
  - {name: 🏠 国内, type: select, proxies: [直连]}
  - {name: 🐟 其他, type: select, proxies: [⚙️ 所有-自动]}

# 节点组定义

  - {name: ⚙️ 所有-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "^((?!(直连)).)*$"}
  - {name: 🇭🇰 香港-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(香港|HK|Hong Kong|🇭🇰|HongKong)).*$"}
  - {name: 🇹🇼 台湾-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(台湾|TW|Tai Wan|🇹🇼|TaiWan|Taiwan)).*$"}
  - {name: 🇸🇬 狮城-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(新加坡|SG|狮城|🇸🇬|Singapore)).*$"}
  - {name: 🇺🇸 美国-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(美|US|🇺🇸|United States)).*$"}
  - {name: 🇯🇵 日本-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(日本|JP|🇯🇵|Japan)).*$"}
  - {name: 🇰🇷 韩国-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "(?=.*(韩国|KR|🇰🇷|Korea)).*$"}
  - {name: 🔄 其他-自动, type: url-test, include-all: true, tolerance: 100, interval: 900, filter: "^((?!(直连|香港|HK|Hong Kong|🇭🇰|HongKong|台湾|TW|Tai Wan|🇹🇼|TaiWan|新加坡|SG|🇸🇬|Singapore|日本|JP|🇯🇵|Japan|韩国|KR|🇰🇷|Korea|美|US|🇺🇸|United States)).)*$"}


# 规则集
rules:
  - RULE-SET,ChatGPT / Domain,ChatGPT
  - RULE-SET,TikTok / Domain,TikTok
  - RULE-SET,Spotify / Domain,Spotify
  - RULE-SET,Disney / Domain,Disney
  - RULE-SET,Netflix / Domain,Netflix
  - RULE-SET,Netflix / IP,Netflix,no-resolve
  - RULE-SET,HBO / Domain,HBO
  - RULE-SET,GitHub / Domain,GitHub
  - RULE-SET,Youtube / Domain,YouTube
  - RULE-SET,Google / Domain,Google
  - RULE-SET,Proxy / Domain,🌐 国外
  - RULE-SET,Globe / Domain,🌐 国外  
  - RULE-SET,Direct / Domain,🏠 国内
  - RULE-SET,China / Domain,🏠 国内
  - RULE-SET,China / IP,🏠 国内,no-resolve
  - RULE-SET,Private / Domain,🏠 国内
  - MATCH,🐟 其他

# 规则集提供者
rule-anchor:
  ip: &ip {type: http, interval: 86400, behavior: ipcidr, format: mrs}
  domain: &domain {type: http, interval: 86400, behavior: domain, format: mrs}
  class: &class {type: http, interval: 86400, behavior: classical, format: text}

rule-providers:
